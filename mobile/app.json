{
  "expo": {
    "name": "Heat Grid",
    "slug": "heat-grid",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "heatgrid",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.heatgrid.app",
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_KEY"
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_KEY"
        }
      },
      "package": "com.heatgrid.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
